# Live Captions — environment variables
# Copy this file to `.env` for local overrides, or set these in your hosting
# provider's environment settings.

# Server port. Most cloud hosts inject their own (Render uses 10000+).
PORT=3000

# Public-facing base URL. Set this in cloud mode if you have a custom domain.
# Examples:
#   PUBLIC_URL=https://live-captions-rexburg.onrender.com
#   PUBLIC_URL=https://livecaptions.example.org
# Leave UNSET to fall back to LAN mode (laptop's local IP).
# On Render, this is auto-set via RENDER_EXTERNAL_URL — no need to configure.
# PUBLIC_URL=

# MyMemory translation quota: anonymous limit is 5,000 chars/day.
# Adding any valid email raises it to 50,000 chars/day. Free either way.
# MYMEMORY_EMAIL=you@example.com

# --- Production stubs (NOT YET WIRED; reserved for Step 9) ---
# DEEPGRAM_API_KEY=
# GOOGLE_TRANSLATE_KEY=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
